{
  "name": "workflow-objects",
  "version": "1.2.1",
  "description": "Create, navigate, clean, and organize metadata-classified notes with schema-aware frontmatter management for a typed object graph workflow.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "workflow",
    "metadata",
    "frontmatter"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "liquidjs": "^10.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "eslint": "^10.0.2",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "obsidian": "^1.5.0",
    "typescript": "^5.3.0"
  }
}
